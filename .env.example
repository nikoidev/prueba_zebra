# === LLM Providers ===
# Al menos una de las tres es necesaria
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Proveedor por defecto: "openai", "anthropic" o "gemini"
DEFAULT_PROVIDER=openai
# Modelos por proveedor:
#   OpenAI:    gpt-4o, gpt-4o-mini, gpt-4-turbo
#   Anthropic: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
#   Gemini:    gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
DEFAULT_MODEL=gpt-4o
FALLBACK_MODEL=gpt-4o-mini

# === Base de Datos ===
DATABASE_URL=postgresql+asyncpg://zebra:zebra_secret@localhost:5432/zebra_agents

# === pgAdmin ===
PGADMIN_EMAIL=admin@zebra.com
PGADMIN_PASSWORD=admin_secret

# === Sistema ===
LOG_LEVEL=INFO
# Umbral de confianza para aceptar el resultado del Reviewer (0.0 - 1.0)
REVIEW_CONFIDENCE_THRESHOLD=0.7
# Maximo de revisiones permitidas en el ciclo Reviewer -> Architect
MAX_REVISIONS=2
MAX_RETRIES=3
